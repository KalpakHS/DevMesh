# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/devmesh

# JWT Authentication Secrets
JWT_SECRET=devmesh_super_secret_jwt_key_12345
JWT_REFRESH_SECRET=devmesh_super_secret_jwt_refresh_key_12345

# Email Settings (Nodemailer)
# Leaving SMTP fields unconfigured will output email contents directly to the server log
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="DevMesh Platform" <noreply@devmesh.com>
ENFORCE_EMAIL_VERIFICATION=false

# Cloudinary Settings
# Leaving Cloudinary fields unconfigured will fall back to local disk storage in /backend/uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# URLs Configuration
FRONTEND_URL=http://localhost:5173
